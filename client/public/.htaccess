# AddiApp SPA — served from public_html. Shipped with the Vite build.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # /api is a symlink to the PHP app (api/public) — let it handle its own routes.
  RewriteRule ^api(/|$) - [L]

  # Serve real files and directories as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else is client-side routing → the SPA entrypoint.
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Security response headers (SEC-1, #107) — top-level `always set` so they ride
  # every response incl. 404/500, on index.html and all asset paths. Origin-level
  # defense-in-depth; Cloudflare is a second layer, not the only one. Apex-only
  # HSTS (no includeSubDomains/preload — see docs/DEPLOY.md). frame-ancestors-only
  # CSP is non-disruptive (blocks iframing only; no script/style restriction).
  Header always set Strict-Transport-Security "max-age=15552000"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Content-Security-Policy "frame-ancestors 'none'"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Long-cache fingerprinted assets; never cache the HTML shell.
  <FilesMatch "\.(?:js|css|woff2?|png|jpg|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
