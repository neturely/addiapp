{
  "name": "addiapp",
  "private": true,
  "version": "1.3.1",
  "type": "module",
  "description": "AddiApp — gamified task app. React+Vite client + PHP/PDO API + MySQL.",
  "license": "MIT",
  "workspaces": [
    "client"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n client,api -c blue,green \"npm:dev:client\" \"npm:dev:api\"",
    "dev:client": "npm run dev -w client",
    "dev:api": "php -S 127.0.0.1:3001 api/router.php",
    "build": "npm run build -w client",
    "typecheck": "npm run typecheck -w client",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:up": "bash scripts/db.sh up",
    "db:down": "bash scripts/db.sh down",
    "db:reset": "bash scripts/db.sh reset",
    "db:migrate": "php api/migrate.php"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
