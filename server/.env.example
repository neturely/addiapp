# Port the Express API listens on (Vite dev server proxies /api to this)
PORT=3001

# MySQL connection. For local dev this points at the Docker Compose container
# (see docker-compose.yml + the repo-root .env). Credentials must match the
# MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE in the root .env.
DATABASE_URL=mysql://addiapp:addiapp@localhost:3306/addiapp
