# Port the Express API listens on (Vite dev server proxies /api to this)
PORT=3001

# MySQL connection. For local dev this points at the Docker Compose container
# (see docker-compose.yml + the repo-root .env). Credentials must match the
# MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE in the root .env.
DATABASE_URL=mysql://addiapp:addiapp@localhost:3306/addiapp

# Timezone whose midnight resets the daily points multiplier (issue #28).
APP_TIMEZONE=Europe/Stockholm

# Frontend base URL — used to build links (e.g. verification) in emails.
APP_URL=http://localhost:5173

# Resend transactional email (issue #61). Leave RESEND_API_KEY empty in dev to
# use the console transport (emails are logged, not sent). Set a real key to send.
# ADDIAPP_EMAIL_FROM defaults to onboarding@resend.dev (works without a verified
# domain); switch to a verified addiapp.com sender for production.
RESEND_API_KEY=
ADDIAPP_EMAIL_FROM=AddiApp <onboarding@resend.dev>
