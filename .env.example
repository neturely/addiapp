# Docker Compose reads this file (repo root) to provision the local MySQL container.
# Copy to `.env` and adjust for your machine. These are LOCAL DEV credentials only.
#
# The PHP API connects to this DB. In local dev it uses its built-in defaults
# (127.0.0.1:3306, addiapp/addiapp) — no extra config needed. In production, copy
# api/config.example.php to api/config.php (outside the web root) with real
# secrets. See api/README.md.

MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=addiapp
MYSQL_USER=addiapp
MYSQL_PASSWORD=addiapp
