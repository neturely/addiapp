# dependencies
node_modules/

# build output
dist/
*.tsbuildinfo

# env (never commit real env; example files are tracked)
.env
.env.*
!.env.example
!**/.env.example

# PHP API secrets (config.example.php is tracked; the real config never is)
api/config.php
api/vendor/

# Dev-only test tooling (Composer/PHPUnit live at the repo root, never deployed)
/vendor/
.phpunit.cache/
.phpunit.result.cache

# logs
*.log
npm-debug.log*

# editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/

# misc
.vercel
*.pem
coverage/
# env files — never commit (any variant or backup)
*.env
*.env.bak
!.env.sample
!.env-example
